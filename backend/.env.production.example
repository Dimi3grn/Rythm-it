# ============================================================
# Production environment variables for Railway
# Copy these into Railway's "Variables" dashboard
# ============================================================

# Application
APP_NAME=Rythmit
APP_ENV=production
APP_VERSION=0.1.0
APP_URL=https://app.dimitrigourrin.dev

# PORT is injected automatically by Railway — do NOT override it
# APP_PORT=8085

# Database (auto-filled by Railway MySQL plugin — or set manually)
DB_HOST=<railway-mysql-host>
DB_PORT=3306
DB_USER=<railway-mysql-user>
DB_PASSWORD=<railway-mysql-password>
DB_NAME=rythmit_db
DB_CHARSET=utf8mb4

# JWT — use a long random secret in production
JWT_SECRET=<generate-with: openssl rand -base64 64>
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=7

# Server timeouts
SERVER_READ_TIMEOUT=15
SERVER_WRITE_TIMEOUT=15
SERVER_IDLE_TIMEOUT=60

# Security
BCRYPT_COST=12
MIN_PASSWORD_LENGTH=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# CORS — add your production domain here (comma-separated)
CORS_ALLOWED_ORIGINS=https://app.dimitrigourrin.dev

# Static asset CDN (Vercel deployment of frontend/styles/)
# Set to your Vercel project URL so CSS/JS are served from Vercel's edge
# Example: https://rythm-it-static.vercel.app
STATIC_BASE_URL=https://<your-vercel-project>.vercel.app
